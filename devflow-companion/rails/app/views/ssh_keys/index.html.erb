<div class="page-header">
  <h1 class="page-title">SSH Keys</h1>
  <p class="page-subtitle">Manage SSH keys and agent</p>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title">Keys in ~/.ssh/</span>
    <span class="badge badge-info"><%= @keys.count %> keys</span>
  </div>
  <table class="data-table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Type</th>
        <th>Fingerprint</th>
        <th>In Agent</th>
        <th>Public Key</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @keys.each do |key| %>
        <tr>
          <td><strong><%= key.name %></strong></td>
          <td><span class="badge badge-neutral"><%= key.type %></span></td>
          <td class="text-mono text-muted" style="font-size: 11px;"><%= key.fingerprint %></td>
          <td>
            <% if key.in_agent %>
              <span class="badge badge-success">Loaded</span>
            <% else %>
              <span class="badge badge-neutral">Not loaded</span>
            <% end %>
          </td>
          <td>
            <% if key.has_public_key? %>
              <span class="badge badge-info">.pub</span>
            <% end %>
          </td>
          <td>
            <% unless key.in_agent %>
              <%= button_to "Add to Agent", add_to_agent_ssh_key_path(key.name), method: :post, class: "btn btn-primary btn-sm" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @keys.empty? %>
    <div class="empty-state">
      <div class="empty-state-icon">&#x1F511;</div>
      <div class="empty-state-title">No SSH Keys</div>
      <div class="empty-state-text">No SSH keys found in ~/.ssh/</div>
    </div>
  <% end %>
</div>
