<div class="card">
  <div class="card-header">
    <span class="card-title">System Prerequisites</span>
    <span class="badge <%= data[:summary][:missing] > 0 ? 'badge-danger' : 'badge-success' %>">
      <%= data[:summary][:ok] %>/<%= data[:summary][:total] %> OK
    </span>
  </div>
  <div class="card-body">
    <% data[:summary][:checks].group_by(&:category).each do |category, checks| %>
      <div style="margin-bottom: 1rem;">
        <h3 style="font-size: 0.875rem; color: #94a3b8; margin-bottom: 0.5rem;"><%= category %></h3>
        <% checks.each do |check| %>
          <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.375rem 0;">
            <span style="color: <%= check.ok? ? '#22c55e' : check.warning? ? '#eab308' : '#ef4444' %>;">
              <%= check.ok? ? '✓' : check.warning? ? '⚠' : '✗' %>
            </span>
            <span><%= check.name %></span>
            <span class="text-muted" style="font-size: 0.75rem;"><%= check.detail %></span>
          </div>
          <% if check.missing? && check.fix_hint.present? %>
            <div style="margin-left: 1.5rem; font-size: 0.75rem; color: #94a3b8;">
              Fix: <code><%= check.fix_hint %></code>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%= form_tag update_step_setup_path, method: :post, style: "margin-top: 1rem;" do %>
      <input type="hidden" name="step" value="prerequisites">
      <button type="submit" class="btn btn-primary">Continue</button>
    <% end %>
  </div>
</div>
