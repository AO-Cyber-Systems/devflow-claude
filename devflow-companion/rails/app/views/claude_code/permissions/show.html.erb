<div class="page-header">
  <h1 class="page-title">Permissions</h1>
  <p class="page-subtitle">Configure Claude Code tool permissions</p>
</div>

<%= form_tag claude_code_permissions_path, method: :patch do %>
  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <span class="card-title">Allow List</span>
    </div>
    <div class="card-body">
      <p class="text-muted" style="margin-bottom: 0.5rem;">Tools and patterns that are always allowed (one per line).</p>
      <textarea name="allow_list" class="form-input" rows="8" placeholder="Bash(git *)&#10;Read&#10;Glob"><%= @permissions["allow"]&.join("\n") %></textarea>
    </div>
  </div>

  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <span class="card-title">Deny List</span>
    </div>
    <div class="card-body">
      <p class="text-muted" style="margin-bottom: 0.5rem;">Tools and patterns that are always denied (one per line).</p>
      <textarea name="deny_list" class="form-input" rows="8" placeholder="Bash(rm -rf *)"><%= @permissions["deny"]&.join("\n") %></textarea>
    </div>
  </div>

  <div class="card" style="margin-bottom: 1.5rem;">
    <div class="card-header">
      <span class="card-title">Dangerous Mode</span>
    </div>
    <div class="card-body">
      <label class="form-check">
        <input type="checkbox" name="skip_dangerous_mode" value="1" <%= "checked" if @permissions["skipDangerousModePermissionPrompt"] %>>
        <span>Skip dangerous mode permission prompt</span>
      </label>
      <small class="text-muted" style="display: block; margin-top: 0.5rem;">When enabled, Claude Code won't prompt before entering dangerous mode.</small>
    </div>
  </div>

  <div style="margin-top: 1rem;">
    <button type="submit" class="btn btn-primary">Save Permissions</button>
  </div>
<% end %>
