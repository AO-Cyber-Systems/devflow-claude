<turbo-frame id="mise-tools-installed">
  <!-- Stats bar -->
  <div style="padding: 12px 16px; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 16px;">
    <span class="text-muted" style="font-size: 12px;">
      <strong style="color: var(--text-primary);"><%= @tools.count %></strong> installed
    </span>
    <span class="text-muted" style="font-size: 12px;">
      <strong style="color: var(--text-primary);"><%= @active_count %></strong> active
    </span>
    <% if @outdated_count > 0 %>
      <span style="font-size: 12px; color: var(--warning);">
        <strong><%= @outdated_count %></strong> outdated
      </span>
    <% end %>
  </div>

  <div data-package-search-target="installedList">
    <% if @tools.empty? %>
      <div class="empty-state">
        <div class="empty-state-icon">&#x1F527;</div>
        <div class="empty-state-title">No tools installed</div>
        <div class="empty-state-text">Use the search bar above to find and install tools from the mise registry</div>
      </div>
    <% else %>
      <% @tools.each do |tool| %>
        <div class="service-row"
             data-package-name="<%= tool.name %>"
             data-package-outdated="<%= tool.outdated? %>">
          <div class="service-info" style="min-width: 0; flex: 1;">
            <div class="service-dot <%= tool.outdated? ? 'stopped' : 'running' %>" style="<%= tool.outdated? ? 'background: var(--warning); box-shadow: 0 0 6px rgba(234,179,8,0.4);' : '' %>"></div>
            <div style="min-width: 0;">
              <div class="flex items-center gap-2">
                <span class="service-name"><%= tool.name %></span>
                <% if tool.active? %>
                  <span class="badge badge-success">active</span>
                <% end %>
              </div>
              <% if tool.source.present? %>
                <div class="service-detail" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 400px;" title="<%= tool.source %>">
                  <%= tool.source %>
                </div>
              <% end %>
            </div>
          </div>
          <div class="flex items-center gap-2" style="flex-shrink: 0;">
            <span class="text-muted" style="font-size: 12px; font-family: var(--font-mono);">
              <%= tool.version %>
              <% if tool.outdated? && tool.latest_version %>
                <span style="color: var(--warning);">&rarr; <%= tool.latest_version %></span>
              <% end %>
            </span>
            <% if tool.outdated? %>
              <button class="btn btn-sm btn-primary"
                      data-controller="package-action"
                      data-package-action-url-value="<%= upgrade_tool_mise_tool_path(tool.name) %>"
                      data-action="package-action#run">
                Upgrade
              </button>
            <% end %>
            <button class="btn btn-sm btn-danger"
                    data-controller="package-action"
                    data-package-action-url-value="<%= uninstall_tool_mise_tool_path(tool.name) %>"
                    data-package-action-params-value="<%= { version: tool.version }.to_json %>"
                    data-package-action-confirm-value="Uninstall <%= tool.name %>@<%= tool.version %>?"
                    data-action="package-action#run">
              Uninstall
            </button>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</turbo-frame>
