<div class="page-header">
  <h1 class="page-title">Git Config</h1>
  <p class="page-subtitle">Global and local git configuration</p>
</div>

<div class="tabs">
  <a href="#global" class="tab active">Global</a>
  <% if @local_config.any? %>
    <a href="#local" class="tab">Local</a>
  <% end %>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title">Global Config (~/.gitconfig)</span>
  </div>
  <div class="desc-list" style="padding: 0 20px;">
    <% @global_config.each do |entry| %>
      <div class="desc-item">
        <span class="desc-key"><%= entry.key %></span>
        <span class="desc-value"><%= entry.value %></span>
      </div>
    <% end %>
  </div>
  <% if @global_config.empty? %>
    <div class="empty-state">
      <div class="empty-state-text">No global git config found</div>
    </div>
  <% end %>
</div>

<div class="card mt-4">
  <div class="card-header">
    <span class="card-title">Edit Setting</span>
  </div>
  <div class="card-body">
    <%= form_with url: git_config_path, method: :patch, local: true do %>
      <div class="form-inline">
        <div class="form-group">
          <label class="form-label">Scope</label>
          <select name="scope" class="form-select">
            <option value="global">Global</option>
            <option value="local">Local</option>
          </select>
        </div>
        <div class="form-group" style="flex: 1;">
          <label class="form-label">Key</label>
          <input type="text" name="key" class="form-input" placeholder="user.name" required>
        </div>
        <div class="form-group" style="flex: 1;">
          <label class="form-label">Value</label>
          <input type="text" name="value" class="form-input" placeholder="Your Name">
        </div>
        <div class="form-group">
          <label class="form-label">&nbsp;</label>
          <button type="submit" class="btn btn-primary">Save</button>
        </div>
      </div>
    <% end %>
  </div>
</div>
