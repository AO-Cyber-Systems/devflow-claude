<% services.each do |service| %>
  <div class="service-row" id="service-<%= service.name %>">
    <div class="service-info">
      <div class="service-dot <%= service.started? ? 'running' : 'stopped' %>"></div>
      <div>
        <div class="service-name"><%= service.name %></div>
        <div class="service-detail">
          <% if service.user %><%= service.user %><% end %>
          <% if service.file %>&middot; <%= File.basename(service.file.to_s) %><% end %>
        </div>
      </div>
    </div>
    <div class="flex items-center gap-2">
      <span class="badge <%= service.started? ? 'badge-success' : 'badge-neutral' %>">
        <%= service.status %>
      </span>
      <div class="btn-group">
        <% if service.started? %>
          <%= button_to "Restart", restart_service_path(service.name), method: :post, class: "btn btn-secondary btn-sm" %>
          <%= button_to "Stop", stop_service_path(service.name), method: :post, class: "btn btn-danger btn-sm" %>
        <% else %>
          <%= button_to "Start", start_service_path(service.name), method: :post, class: "btn btn-primary btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
<% if services.empty? %>
  <div class="empty-state">
    <div class="empty-state-icon">&#x2699;</div>
    <div class="empty-state-title">No Services Found</div>
    <div class="empty-state-text">Install services with <code>brew install</code> to manage them here.</div>
  </div>
<% end %>
