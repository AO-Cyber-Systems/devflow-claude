<%= turbo_frame_tag "prompt-run-#{prompt_run.id}" do %>
  <div class="p-3 rounded-lg border border-gray-700 bg-gray-900 mb-2">
    <div class="flex items-center justify-between mb-1">
      <span class="text-xs font-mono
        <%= case prompt_run.status
            when 'queued' then 'text-gray-400'
            when 'running' then 'text-blue-400'
            when 'completed' then 'text-green-400'
            when 'failed' then 'text-red-400'
            end %>">
        <%= prompt_run.status.upcase %>
      </span>
      <span class="text-xs text-gray-500"><%= time_ago_in_words(prompt_run.created_at) %> ago</span>
    </div>
    <p class="text-sm text-gray-300"><%= prompt_run.prompt.truncate(200) %></p>
    <% if prompt_run.completed? && prompt_run.result.present? %>
      <details class="mt-2">
        <summary class="text-xs text-gray-500 cursor-pointer">View output</summary>
        <pre class="mt-1 text-xs text-gray-400 overflow-x-auto max-h-40 overflow-y-auto"><%= prompt_run.result.truncate(2000) %></pre>
      </details>
    <% end %>
    <% if prompt_run.failed? && prompt_run.result.present? %>
      <p class="mt-1 text-xs text-red-400"><%= prompt_run.result.truncate(200) %></p>
    <% end %>
  </div>
<% end %>
