<div id="work-summary-<%= summary.id %>" class="p-3 border-l-2 border-gray-700 mb-2 <%= summary.read? ? 'opacity-60' : '' %>">
  <div class="text-xs text-gray-500 mb-1"><%= time_ago_in_words(summary.created_at) %> ago</div>
  <div class="text-sm text-gray-300 line-clamp-3"><%= simple_format(summary.content.truncate(500)) %></div>
</div>
