<%= turbo_frame_tag "relay-session-#{session.id}" do %>
  <a href="<%= relay_session_path(session) %>"
     class="block p-4 rounded-xl border-l-4 bg-gray-900 mb-3 hover:bg-gray-800 transition"
     style="border-left-color: <%= session.session_color || '#6366F1' %>"
     data-turbo-frame="_top">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="w-3 h-3 rounded-full" style="background-color: <%= session.session_color || '#6366F1' %>"></span>
        <span class="font-semibold"><%= session.project_name || session.name %></span>
        <% if session.branch.present? %>
          <span class="text-xs text-gray-400">(<%= session.branch %>)</span>
        <% end %>
      </div>
      <span class="text-xs px-2 py-0.5 rounded-full bg-gray-800 text-gray-400"><%= session.ide %></span>
    </div>
    <div class="mt-2 flex items-center gap-3 text-sm text-gray-400">
      <span class="capitalize"><%= session.autonomy_level %></span>
      <% if session.pending_requests_count > 0 %>
        <span class="px-2 py-0.5 rounded-full bg-amber-900 text-amber-300 text-xs font-medium">
          <%= session.pending_requests_count %> pending
        </span>
      <% end %>
    </div>
  </a>
<% end %>
