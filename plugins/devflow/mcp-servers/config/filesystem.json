{
  "name": "filesystem",
  "description": "Secure file operations with access controls",
  "command": "npx",
  "args": [
    "@anthropic-ai/mcp-server-filesystem",
    "--allowed-directories",
    "${PROJECT_ROOT}"
  ],
  "env": {},
  "tools": [
    "read_file",
    "read_multiple_files",
    "write_file",
    "create_directory",
    "list_directory",
    "move_file",
    "search_files",
    "get_file_info",
    "list_allowed_directories"
  ],
  "notes": {
    "security": "Restricted to project directory only",
    "usage": "Replace ${PROJECT_ROOT} with actual project path on registration"
  }
}
