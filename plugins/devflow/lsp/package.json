{
  "name": "devflow-lsp",
  "version": "1.0.0",
  "private": true,
  "description": "Bundled LSP servers for DevFlow Agent plugin",
  "dependencies": {
    "typescript": "^5.0.0",
    "typescript-language-server": "^4.0.0",
    "svelte-language-server": "^0.16.0",
    "pyright": "^1.1.0",
    "@tailwindcss/language-server": "^0.0.27",
    "vscode-json-languageserver": "^1.3.0",
    "yaml-language-server": "^1.15.0",
    "solargraph": "^0.50.0"
  },
  "bin": {
    "typescript-language-server": "./node_modules/.bin/typescript-language-server",
    "svelte-language-server": "./node_modules/.bin/svelteserver",
    "pyright-langserver": "./node_modules/.bin/pyright-langserver",
    "tailwindcss-language-server": "./node_modules/.bin/tailwindcss-language-server",
    "yaml-language-server": "./node_modules/.bin/yaml-language-server",
    "json-language-server": "./node_modules/.bin/vscode-json-languageserver"
  },
  "scripts": {
    "postinstall": "echo 'LSP servers installed successfully'"
  }
}
